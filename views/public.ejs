<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= settings.site_name || 'Happy Dragon Tours' %> · Beijing Premium Travel</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--clr-white:#fff;--clr-bg:#fcf9f6;--clr-surface:#fff;--clr-text:#1c1917;--clr-muted:#78716c;--clr-border:#e6e0d8;--clr-primary:#b91c1c;--clr-primary-dark:#7f1d1d;--clr-primary-light:#fef2f2;--clr-gold:#c8a96e;--clr-gold-light:#fef9ec;--clr-gold-dark:#a07d3e;--clr-overlay:rgba(28,25,23,.55);--ff-sans:'Inter',system-ui,sans-serif;--ff-serif:'Playfair Display',Georgia,serif;--max-w:1200px;--nav-h:72px;--radius:6px;--radius-lg:10px;--shadow-sm:0 1px 3px rgba(0,0,0,.06);--shadow-md:0 4px 14px rgba(0,0,0,.08);--shadow-lg:0 10px 40px rgba(0,0,0,.12);--transition:350ms cubic-bezier(.4,0,.2,1)}
html{scroll-behavior:smooth}body{font-family:var(--ff-sans);color:var(--clr-text);background:var(--clr-bg);line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}img{display:block;max-width:100%;height:auto}
.container{width:100%;max-width:var(--max-w);margin:0 auto;padding:0 24px}section{padding:96px 0}::selection{background:var(--clr-primary);color:var(--clr-white)}
.pattern-divider{height:6px;background:repeating-linear-gradient(90deg,var(--clr-gold) 0,var(--clr-gold) 2px,transparent 2px,transparent 6px);opacity:.3}

.nav{position:fixed;top:0;left:0;right:0;z-index:1000;height:var(--nav-h);display:flex;align-items:center;transition:var(--transition);background:transparent}
.nav--solid{background:var(--clr-white);box-shadow:var(--shadow-sm)}
.nav__inner{display:flex;align-items:center;justify-content:space-between;width:100%;max-width:var(--max-w);margin:0 auto;padding:0 24px}
.nav__logo{display:flex;align-items:center;gap:10px;color:var(--clr-white);transition:var(--transition)}
.nav--solid .nav__logo{color:var(--clr-primary)}
.nav__logo-icon{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;background:var(--clr-gold);border-radius:50%;color:var(--clr-white);font-size:1rem;font-weight:700;font-family:var(--ff-serif);transition:var(--transition)}
.nav--solid .nav__logo-icon{background:var(--clr-primary)}
.nav__logo-text{display:flex;flex-direction:column;line-height:1.15}
.nav__logo-name{font-family:var(--ff-serif);font-size:1.15rem;font-weight:700}
.nav__logo-tag{font-size:.65rem;letter-spacing:1.5px;text-transform:uppercase;opacity:.65;font-weight:500}
.nav__links{display:flex;align-items:center;gap:28px;list-style:none}
.nav__links a{font-size:.85rem;font-weight:500;color:rgba(255,255,255,.85);transition:var(--transition);position:relative;padding:4px 0}
.nav__links a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:2px;background:var(--clr-gold);transition:var(--transition)}
.nav--solid .nav__links a{color:var(--clr-muted)}
.nav--solid .nav__links a::after{background:var(--clr-primary)}
.nav__links a:hover::after{width:100%}.nav__links a:hover{color:var(--clr-white)}
.nav--solid .nav__links a:hover{color:var(--clr-text)}
.nav__cta{padding:10px 24px !important;background:var(--clr-gold);color:var(--clr-white) !important;border-radius:var(--radius);font-weight:600;transition:var(--transition)}
.nav--solid .nav__cta{background:var(--clr-primary);color:var(--clr-white) !important}
.nav__cta:hover{background:var(--clr-gold-dark) !important;box-shadow:var(--shadow-md);transform:translateY(-1px)}
.nav--solid .nav__cta:hover{background:var(--clr-primary-dark) !important}.nav__cta::after{display:none !important}
.nav__toggle{display:none;background:none;border:none;color:var(--clr-white);cursor:pointer;padding:4px}
.nav--solid .nav__toggle{color:var(--clr-text)}

.hero{position:relative;min-height:100vh;display:flex;align-items:center;background:#1a1a1a;overflow:hidden}
.hero__bg{position:absolute;inset:0;z-index:0;background:url('https://images.unsplash.com/photo-1508804185872-d7badad00f7d?w=1920&q=80') center/cover no-repeat;opacity:.45}
.hero__bg::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(128,0,0,.25) 0%,transparent 50%,rgba(0,0,0,.3) 100%)}
.hero__pattern{position:absolute;inset:0;z-index:0;opacity:.06;background-image:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")}
.hero__overlay{position:relative;z-index:1;width:100%;max-width:var(--max-w);margin:0 auto;padding:0 24px}
.hero__seal{display:inline-flex;align-items:center;gap:8px;padding:8px 20px;background:rgba(200,169,110,.15);border:1px solid rgba(200,169,110,.3);border-radius:100px;font-size:.78rem;font-weight:500;letter-spacing:1.2px;color:var(--clr-gold);text-transform:uppercase;margin-bottom:28px;backdrop-filter:blur(4px)}
.hero__seal::before{content:'';display:block;width:6px;height:6px;background:var(--clr-gold);border-radius:50%}
.hero__title{font-family:var(--ff-serif);font-size:clamp(2.8rem,7vw,5rem);font-weight:700;line-height:1.05;color:var(--clr-white);max-width:800px;margin-bottom:12px}
.hero__title em{font-style:italic;background:linear-gradient(135deg,var(--clr-gold),#f5d99e);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero__sub{font-size:clamp(1rem,2vw,1.2rem);color:rgba(255,255,255,.72);max-width:580px;line-height:1.7;margin-bottom:16px}
.hero__actions{display:flex;gap:16px;flex-wrap:wrap;margin-top:12px}
.btn{display:inline-flex;align-items:center;gap:8px;padding:14px 30px;border-radius:var(--radius);font-size:.95rem;font-weight:600;border:none;cursor:pointer;transition:var(--transition);font-family:var(--ff-sans)}
.btn--primary{background:var(--clr-gold);color:var(--clr-white)}
.btn--primary:hover{box-shadow:var(--shadow-lg);transform:translateY(-2px);background:var(--clr-gold-dark)}
.btn--outline{background:transparent;color:var(--clr-white);border:1.5px solid rgba(255,255,255,.35)}
.btn--outline:hover{background:rgba(255,255,255,.1);border-color:var(--clr-white)}
.btn--ghost{background:var(--clr-primary);color:var(--clr-white)}
.btn--ghost:hover{background:var(--clr-primary-dark);box-shadow:var(--shadow-md);transform:translateY(-1px)}
.hero__scroll{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);z-index:1;display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(255,255,255,.5);font-size:.7rem;letter-spacing:2.5px;text-transform:uppercase;animation:float 2.4s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(-10px)}}

.section__header{text-align:center;max-width:680px;margin:0 auto 56px}
.section__label{display:inline-flex;align-items:center;gap:10px;padding:4px 16px;background:var(--clr-primary-light);color:var(--clr-primary-dark);border-radius:100px;font-size:.75rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:16px}
.section__label::before,.section__label::after{content:'';display:block;width:16px;height:1px;background:var(--clr-primary);opacity:.3}
.section__title{font-family:var(--ff-serif);font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:700;line-height:1.2;margin-bottom:14px;color:var(--clr-text)}
.section__desc{color:var(--clr-muted);font-size:clamp(.95rem,1.2vw,1.05rem);line-height:1.7}

.about{background:var(--clr-surface);padding-bottom:0}
.about__inner{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.about__image{border-radius:var(--radius-lg);overflow:hidden;position:relative}
.about__image img{width:100%;height:400px;object-fit:cover}
.about__image-border{position:absolute;top:12px;left:12px;right:-12px;bottom:-12px;border:2px solid var(--clr-gold);border-radius:var(--radius-lg);z-index:-1;opacity:.4}
.about__content{padding:20px 0}
.about__content .section__header{text-align:left;margin:0 0 24px}
.about__content .section__label::before,.about__content .section__label::after{display:none}
.about__text{color:var(--clr-muted);font-size:.95rem;line-height:1.8;margin-bottom:20px}
.about__stats{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:32px}
.about__stat{text-align:center}
.about__stat-num{font-family:var(--ff-serif);font-size:2rem;font-weight:700;color:var(--clr-primary)}
.about__stat-label{font-size:.8rem;color:var(--clr-muted);margin-top:4px}

.hotels{background:var(--clr-bg)}
.hotel-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:28px}
.hotel-card{background:var(--clr-white);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);transition:var(--transition)}
.hotel-card:hover{box-shadow:var(--shadow-lg);transform:translateY(-4px)}
.hotel-card__img{aspect-ratio:16/10;overflow:hidden}
.hotel-card__img img,.hotel-card__img-placeholder{width:100%;height:100%;object-fit:cover;transition:transform 500ms ease}
.hotel-card:hover .hotel-card__img img,.hotel-card:hover .hotel-card__img-placeholder{transform:scale(1.05)}
.hotel-card__img-placeholder{background:linear-gradient(135deg,#e6e0d8,#d4cec6);display:flex;align-items:center;justify-content:center;color:#a09a92;font-size:.8rem}
.hotel-card__body{padding:24px 28px 28px}
.hotel-card__title{font-family:var(--ff-serif);font-size:1.25rem;font-weight:700;margin-bottom:8px}
.hotel-card__location{display:flex;align-items:center;gap:6px;font-size:.82rem;color:var(--clr-muted);margin-bottom:12px}
.hotel-card__desc{font-size:.9rem;color:var(--clr-muted);line-height:1.7;margin-bottom:16px}
.hotel-card__tags{display:flex;flex-wrap:wrap;gap:8px}
.hotel-card__tag{padding:4px 10px;background:var(--clr-primary-light);color:var(--clr-primary-dark);border-radius:100px;font-size:.72rem;font-weight:500}

.tours{background:var(--clr-surface)}
.tour-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px}
.tour-card{background:var(--clr-bg);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);transition:var(--transition);border:1px solid var(--clr-border)}
.tour-card:hover{box-shadow:var(--shadow-md);transform:translateY(-3px);border-color:var(--clr-gold)}
.tour-card__img{aspect-ratio:16/9;overflow:hidden;background:#e6e0d8}
.tour-card__img img,.tour-card__img-place{width:100%;height:100%;object-fit:cover;transition:transform 500ms ease;display:flex;align-items:center;justify-content:center;color:#a09a92;font-size:.75rem}
.tour-card:hover .tour-card__img img,.tour-card:hover .tour-card__img-place{transform:scale(1.05)}
.tour-card__body{padding:22px 24px 24px}
.tour-card__label{display:inline-block;padding:2px 10px;background:var(--clr-gold-light);color:var(--clr-gold-dark);border-radius:100px;font-size:.7rem;font-weight:600;letter-spacing:.5px;text-transform:uppercase;margin-bottom:10px}
.tour-card__title{font-family:var(--ff-serif);font-size:1.1rem;font-weight:700;margin-bottom:8px}
.tour-card__desc{font-size:.85rem;color:var(--clr-muted);line-height:1.6;margin-bottom:14px}
.tour-card__meta{display:flex;align-items:center;gap:16px;flex-wrap:wrap;font-size:.8rem;color:var(--clr-muted);padding-top:14px;border-top:1px solid var(--clr-border)}
.tour-card__meta-item{display:flex;align-items:center;gap:5px}
.tour-card__footer{display:flex;align-items:center;justify-content:space-between;margin-top:16px}
.tour-card__price{font-family:var(--ff-serif);font-size:1.1rem;font-weight:700;color:var(--clr-primary)}
.tour-card__price small{font-family:var(--ff-sans);font-size:.7rem;font-weight:400;color:var(--clr-muted)}
.tour-card__btn{padding:8px 18px;background:var(--clr-primary);color:var(--clr-white);border:none;border-radius:var(--radius);font-family:var(--ff-sans);font-size:.8rem;font-weight:600;cursor:pointer;transition:var(--transition)}
.tour-card__btn:hover{background:var(--clr-primary-dark)}

.journeys{background:var(--clr-bg)}
.journey-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:32px}
.journey-card{position:relative;border-radius:var(--radius-lg);overflow:hidden;min-height:420px;display:flex;align-items:flex-end;cursor:pointer}
.journey-card__bg{position:absolute;inset:0;z-index:0}
.journey-card__bg img,.journey-card__bg-place{width:100%;height:100%;object-fit:cover;transition:transform 600ms ease;background:linear-gradient(135deg,#e6e0d8,#d4cec6);display:flex;align-items:center;justify-content:center;color:#a09a92;font-size:.8rem}
.journey-card:hover .journey-card__bg img{transform:scale(1.06)}
.journey-card__bg::after{content:'';position:absolute;inset:0;background:linear-gradient(transparent 20%,rgba(0,0,0,.7))}
.journey-card__content{position:relative;z-index:1;padding:36px 32px;color:var(--clr-white);width:100%}
.journey-card__region{display:inline-block;padding:3px 12px;background:rgba(200,169,110,.2);border:1px solid rgba(200,169,110,.4);border-radius:100px;font-size:.7rem;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--clr-gold);margin-bottom:12px}
.journey-card__title{font-family:var(--ff-serif);font-size:1.4rem;font-weight:700;margin-bottom:8px}
.journey-card__desc{font-size:.85rem;line-height:1.6;opacity:.85;margin-bottom:16px;max-width:420px}
.journey-card__link{display:inline-flex;align-items:center;gap:6px;font-size:.85rem;font-weight:600;color:var(--clr-gold)}

.testimonials{background:var(--clr-surface)}
.test-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:24px}
.test-card{background:var(--clr-bg);border-radius:var(--radius-lg);padding:36px 32px;border:1px solid var(--clr-border);transition:var(--transition)}
.test-card:hover{border-color:var(--clr-gold);box-shadow:var(--shadow-sm)}
.test-card__stars{display:flex;gap:3px;margin-bottom:14px;color:var(--clr-gold)}
.test-card__text{font-size:.9rem;line-height:1.7;color:var(--clr-muted);margin-bottom:20px;font-style:italic}
.test-card__author{display:flex;align-items:center;gap:14px}
.test-card__avatar{width:42px;height:42px;border-radius:50%;background:var(--clr-primary-light);color:var(--clr-primary);display:flex;align-items:center;justify-content:center;font-weight:600;font-size:.85rem;text-transform:uppercase}
.test-card__name{font-size:.88rem;font-weight:600}
.test-card__origin{font-size:.78rem;color:var(--clr-muted)}

.gallery{padding-bottom:0}
.gallery .section__header{margin-bottom:40px}
.gallery-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:0}
.gallery-strip__item{aspect-ratio:1;overflow:hidden;position:relative;background:var(--clr-border)}
.gallery-strip__item img{width:100%;height:100%;object-fit:cover;transition:transform 600ms ease}
.gallery-strip__item:hover img{transform:scale(1.08)}
.gallery-strip__item::after{content:'';position:absolute;inset:0;background:linear-gradient(transparent 50%,rgba(0,0,0,.25));transition:var(--transition)}

.booking{background:linear-gradient(135deg,var(--clr-primary-dark),var(--clr-primary));color:var(--clr-white)}
.booking .section__title{color:var(--clr-white)}
.booking .section__desc{color:rgba(255,255,255,.7)}
.booking .section__label{background:rgba(255,255,255,.12);color:var(--clr-white)}
.booking .section__label::before,.booking .section__label::after{background:var(--clr-white)}
.booking__inner{display:grid;grid-template-columns:1fr 1.2fr;gap:56px;align-items:start}
.booking__info{display:flex;flex-direction:column;gap:16px}
.booking__item{display:flex;align-items:flex-start;gap:14px;padding:16px;background:rgba(255,255,255,.06);border-radius:var(--radius);border:1px solid rgba(255,255,255,.08)}
.booking__item-icon{width:40px;height:40px;flex-shrink:0;background:rgba(200,169,110,.2);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;color:var(--clr-gold)}
.booking__item-title{font-size:.9rem;font-weight:600;margin-bottom:2px}
.booking__item-desc{font-size:.82rem;color:rgba(255,255,255,.6);line-height:1.5}
.booking__form{background:var(--clr-white);border-radius:var(--radius-lg);padding:36px;display:flex;flex-direction:column;gap:14px;color:var(--clr-text)}
.booking__form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.booking__form label{font-size:.8rem;font-weight:600;display:flex;flex-direction:column;gap:4px}
.booking__form select,.booking__form input,.booking__form textarea{padding:10px 14px;border:1px solid var(--clr-border);border-radius:var(--radius);font-family:var(--ff-sans);font-size:.9rem;color:var(--clr-text);outline:none;transition:var(--transition);background:var(--clr-white);width:100%}
.booking__form select:focus,.booking__form input:focus,.booking__form textarea:focus{border-color:var(--clr-primary);box-shadow:0 0 0 3px rgba(185,28,28,.1)}
.booking__form textarea{min-height:100px;resize:vertical}
.booking__form .btn--ghost{justify-content:center;width:100%;padding:14px}
.booking__message{display:none;padding:12px 16px;background:rgba(255,255,255,.15);border-radius:var(--radius);font-size:.9rem;color:#fff;margin-bottom:8px}

.footer{background:#1a1513;color:rgba(255,255,255,.55);padding:48px 0 32px;font-size:.82rem}
.footer__inner{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}
.footer__brand{display:flex;align-items:center;gap:10px;color:rgba(255,255,255,.75)}
.footer__brand-icon{display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;background:var(--clr-gold);border-radius:50%;color:var(--clr-white);font-size:.7rem;font-weight:700;font-family:var(--ff-serif)}
.footer__links{display:flex;gap:24px;list-style:none}
.footer__links a{transition:var(--transition)}
.footer__links a:hover{color:var(--clr-white)}
.footer__divider{height:1px;background:rgba(255,255,255,.08);margin:24px 0}
.footer__bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}

@media(max-width:1024px){.about__inner{grid-template-columns:1fr;gap:40px}.about__image{order:-1}.booking__inner{grid-template-columns:1fr;gap:40px}}
@media(max-width:900px){.gallery-strip{grid-template-columns:repeat(2,1fr)}}
@media(max-width:768px){section{padding:72px 0}
.nav__toggle{display:flex;align-items:center;justify-content:center}
.nav__links{position:fixed;top:var(--nav-h);left:0;right:0;flex-direction:column;gap:0;background:var(--clr-white);padding:8px 0;box-shadow:var(--shadow-md);transform:translateY(-110%);opacity:0;transition:var(--transition);pointer-events:none}
.nav__links--open{transform:translateY(0);opacity:1;pointer-events:auto}
.nav__links a{padding:14px 24px;color:var(--clr-muted) !important;border-bottom:1px solid var(--clr-border)}
.nav__links a::after{display:none}.nav__cta{display:none}
.about__stats{grid-template-columns:repeat(3,1fr)}
.hotel-grid,.tour-grid,.journey-grid,.test-grid{grid-template-columns:1fr}
.booking__form-row{grid-template-columns:1fr}}
@media(max-width:540px){.about__stats{grid-template-columns:1fr;gap:16px}.hero__actions{flex-direction:column}.hero__actions .btn{justify-content:center}}
</style>
</head>
<body>

<!-- Navigation -->
<nav class="nav" id="nav">
  <div class="nav__inner">
    <a href="#" class="nav__logo">
      <span class="nav__logo-icon">龙</span>
      <span class="nav__logo-text">
        <span class="nav__logo-name">Happy Dragon</span>
        <span class="nav__logo-tag">Beijing Tours</span>
      </span>
    </a>
    <button class="nav__toggle" id="navToggle" aria-label="Menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <ul class="nav__links" id="navLinks">
      <li><a href="#hotels">Hotels</a></li>
      <li><a href="#tours">Tours</a></li>
      <li><a href="#journeys">Extended</a></li>
      <li><a href="#testimonials">Reviews</a></li>
      <li><a href="#booking" class="nav__cta">Book Now</a></li>
    </ul>
  </div>
</nav>

<!-- Hero -->
<section class="hero" id="hero">
  <div class="hero__bg"></div>
  <div class="hero__pattern"></div>
  <div class="hero__overlay">
    <div class="hero__seal"><%= hero.badge || 'Since 2008 · Beijing & Beyond' %></div>
    <h1 class="hero__title"><%= hero.title_line1 || 'Discover China\'s' %><br><em><%= hero.title_line2 || 'Timeless Capital' %></em></h1>
    <p class="hero__sub"><%= hero.subtitle || 'From the Great Wall to hidden hutong alleys, experience Beijing with premium accommodations and expertly curated day tours.' %></p>
    <div class="hero__actions">
      <a href="#tours" class="btn btn--primary">
        <%= hero.cta1_text || 'Explore Tours' %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="#booking" class="btn btn--outline"><%= hero.cta2_text || 'Book Now' %></a>
    </div>
  </div>
  <div class="hero__scroll"><span>Discover</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></div>
</section>

<!-- About -->
<section class="about" id="about">
  <div class="container">
    <div class="about__inner">
      <div class="about__image">
        <img src="https://images.unsplash.com/photo-1570459036415-bd3fade60a6c?w=700&q=80" alt="Forbidden City" loading="lazy">
        <div class="about__image-border"></div>
      </div>
      <div class="about__content">
        <div class="section__header">
          <span class="section__label"><%= about.label || 'About Us' %></span>
          <h2 class="section__title"><%= about.title || 'Your Gateway to China' %></h2>
        </div>
        <p class="about__text"><%= about.paragraph1 || 'With over 15 years of experience, Happy Dragon Tours brings together premium accommodations and authentic travel experiences in Beijing.' %></p>
        <% if (about.paragraph2) { %><p class="about__text"><%= about.paragraph2 %></p><% } %>
        <div class="about__stats">
          <div class="about__stat"><div class="about__stat-num"><%= about.stat1_num || '15+' %></div><div class="about__stat-label"><%= about.stat1_label || 'Years Experience' %></div></div>
          <div class="about__stat"><div class="about__stat-num"><%= about.stat2_num || '5K+' %></div><div class="about__stat-label"><%= about.stat2_label || 'Happy Guests' %></div></div>
          <div class="about__stat"><div class="about__stat-num"><%= about.stat3_num || '40+' %></div><div class="about__stat-label"><%= about.stat3_label || 'Destinations' %></div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="pattern-divider"></div>

<!-- Hotels -->
<section class="hotels" id="hotels">
  <div class="container">
    <div class="section__header">
      <span class="section__label">Accommodations</span>
      <h2 class="section__title">Our Hotels in Beijing</h2>
      <p class="section__desc">Centrally located properties that blend Chinese hospitality with modern comfort.</p>
    </div>
    <div class="hotel-grid">
      <% if (hotels.length === 0) { %>
      <p style="grid-column:1/-1;text-align:center;color:var(--clr-muted);padding:40px 0">Hotels coming soon.</p>
      <% } else { hotels.forEach(h => { %>
      <div class="hotel-card">
        <div class="hotel-card__img">
          <% if (h.image) { %><img src="<%= h.image.startsWith('/') ? h.image : '/uploads/' + h.image %>" alt="<%= h.name %>" loading="lazy"><% } else { %><div class="hotel-card__img-placeholder"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div><% } %>
        </div>
        <div class="hotel-card__body">
          <h3 class="hotel-card__title"><%= h.name %></h3>
          <div class="hotel-card__location"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><span><%= h.location %></span></div>
          <p class="hotel-card__desc"><%= h.description %></p>
          <a href="/hotel/<%= h.id %>" style="display:inline-flex;align-items:center;gap:4px;font-size:.82rem;font-weight:600;color:var(--clr-primary);margin-bottom:12px">View Hotel Details<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
          <div class="hotel-card__tags"><% (h.tags||'').split(',').filter(t=>t).forEach(t => { %><span class="hotel-card__tag"><%= t.trim() %></span><% }) %></div>
        </div>
      </div>
      <% }) } %>
    </div>
  </div>
</section>

<!-- Tours -->
<section class="tours" id="tours">
  <div class="container">
    <div class="section__header">
      <span class="section__label">Beijing Day Tours</span>
      <h2 class="section__title">Explore the Capital</h2>
      <p class="section__desc">Expert-led tours designed to show you the best of Beijing. Includes hotel pickup, English-speaking guide, and entrance fees.</p>
    </div>
    <div class="tour-grid">
      <% if (tours.length === 0) { %>
      <p style="grid-column:1/-1;text-align:center;color:var(--clr-muted);padding:40px 0">Tours coming soon.</p>
      <% } else { tours.forEach(t => { %>
      <div class="tour-card">
        <div class="tour-card__img">
          <% if (t.image) { %><img src="<%= t.image.startsWith('/') ? t.image : '/uploads/' + t.image %>" alt="<%= t.title %>" loading="lazy"><% } else { %><div class="tour-card__img-place"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 6.9 8 11.7z"/></svg></div><% } %>
        </div>
        <div class="tour-card__body">
          <% if (t.label) { %><span class="tour-card__label"><%= t.label %></span><% } %>
          <h3 class="tour-card__title"><%= t.title %></h3>
          <p class="tour-card__desc"><%= t.description %></p>
          <div class="tour-card__meta">
            <% if (t.duration) { %><span class="tour-card__meta-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><%= t.duration %></span><% } %>
            <% if (t.tour_type) { %><span class="tour-card__meta-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg><%= t.tour_type %></span><% } %>
          </div>
          <div class="tour-card__footer">
            <span class="tour-card__price"><%= t.price || 'Inquire' %> <% if (t.price) { %><small>/ person</small><% } %></span>
            <a href="/tour/<%= t.id %>" class="tour-card__btn" style="text-decoration:none;display:inline-flex;align-items:center;gap:4px">View Details<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
          </div>
        </div>
      </div>
      <% }) } %>
    </div>
  </div>
</section>

<!-- Extended Journeys -->
<section class="journeys" id="journeys">
  <div class="container">
    <div class="section__header">
      <span class="section__label">Partner Journeys</span>
      <h2 class="section__title">Beyond Beijing</h2>
      <p class="section__desc">Extend your China adventure to two extraordinary regions, operated by our trusted partners.</p>
    </div>
    <div class="journey-grid">
      <% if (journeys.length === 0) { %>
      <p style="grid-column:1/-1;text-align:center;color:var(--clr-muted);padding:40px 0">Journeys coming soon.</p>
      <% } else { journeys.forEach(j => { %>
      <div class="journey-card">
        <div class="journey-card__bg">
          <% if (j.image) { %><img src="<%= j.image.startsWith('/') ? j.image : '/uploads/' + j.image %>" alt="<%= j.title %>" loading="lazy"><% } else { %><div class="journey-card__bg-place"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 1-6 6"/><path d="M6 8a10 10 0 0 0 10 10"/><circle cx="12" cy="6" r="4"/></svg></div><% } %>
        </div>
        <div class="journey-card__content">
          <span class="journey-card__region"><%= j.region %></span>
          <h3 class="journey-card__title"><%= j.title %></h3>
          <p class="journey-card__desc"><%= j.description %></p>
          <a href="/journey/<%= j.id %>" class="journey-card__link">View Details<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
        </div>
      </div>
      <% }) } %>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="testimonials" id="testimonials">
  <div class="container">
    <div class="section__header">
      <span class="section__label">Guest Reviews</span>
      <h2 class="section__title">What Our Guests Say</h2>
      <p class="section__desc">Real reviews from travelers who have experienced China with us.</p>
    </div>
    <div class="test-grid">
      <% if (testimonials.length === 0) { %>
      <p style="grid-column:1/-1;text-align:center;color:var(--clr-muted);padding:40px 0">Reviews coming soon.</p>
      <% } else { testimonials.forEach(t => { %>
      <div class="test-card">
        <div class="test-card__stars"><% for (let s=0; s<t.rating; s++) { %><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg><% } %></div>
        <p class="test-card__text">"<%= t.text %>"</p>
        <div class="test-card__author">
          <div class="test-card__avatar"><%= t.avatar_initials || t.name.substring(0,2).toUpperCase() %></div>
          <div>
            <div class="test-card__name"><%= t.name %></div>
            <div class="test-card__origin"><%= t.origin || '' %></div>
          </div>
        </div>
      </div>
      <% }) } %>
    </div>
  </div>
</section>

<!-- Gallery -->
<section class="gallery">
  <div class="container">
    <div class="section__header">
      <span class="section__label">Moments of China</span>
      <h2 class="section__title">Captured Along the Way</h2>
    </div>
  </div>
  <div class="gallery-strip">
    <% if (gallery.length === 0) { %>
    <% const fallback = ['https://images.unsplash.com/photo-1552414400-8c13bb7b822c?w=400&q=80','https://images.unsplash.com/photo-1528164344705-47542687000d?w=400&q=80','https://images.unsplash.com/photo-1502790671504-542ad42d5189?w=400&q=80','https://images.unsplash.com/photo-1494783367193-149034c05e8f?w=400&q=80']; %>
    <% for (let i=0; i<4; i++) { %><div class="gallery-strip__item"><img src="<%= fallback[i] %>" alt="" loading="lazy"></div><% } %>
    <% } else { gallery.forEach(g => { %>
    <div class="gallery-strip__item"><img src="/uploads/<%= g.filename %>" alt="<%= g.alt_text || '' %>" loading="lazy"></div>
    <% }) } %>
  </div>
</section>

<!-- Booking -->
<section class="booking" id="booking">
  <div class="container">
    <div class="section__header">
      <span class="section__label">Book Your Experience</span>
      <h2 class="section__title">Let's Plan Your Trip</h2>
      <p class="section__desc">Fill out the form below and our team will get back to you within 24 hours with a personalized itinerary.</p>
    </div>
    <div class="booking__inner">
      <div class="booking__info">
        <div class="booking__item">
          <div class="booking__item-icon" data-lucide="phone"></div>
          <div><p class="booking__item-title">Call Us</p><p class="booking__item-desc"><%= settings.contact_phone %><br><%= settings.contact_phone2 %></p></div>
        </div>
        <div class="booking__item">
          <div class="booking__item-icon" data-lucide="mail"></div>
          <div><p class="booking__item-title">Email</p><p class="booking__item-desc"><%= settings.contact_email %></p></div>
        </div>
        <div class="booking__item">
          <div class="booking__item-icon" data-lucide="map-pin"></div>
          <div><p class="booking__item-title">Visit Us</p><p class="booking__item-desc"><%= settings.contact_address %></p></div>
        </div>
        <div class="booking__item">
          <div class="booking__item-icon" data-lucide="clock"></div>
          <div><p class="booking__item-title">Office Hours</p><p class="booking__item-desc"><%= settings.contact_hours %></p></div>
        </div>
      </div>
      <form class="booking__form" id="bookingForm">
        <div id="formMessage" class="booking__message"></div>
        <div class="booking__form-row">
          <label>Full Name<input type="text" name="name" placeholder="e.g. John Smith" required></label>
          <label>Email<input type="email" name="email" placeholder="john@example.com" required></label>
        </div>
        <div class="booking__form-row">
          <label>Nationality<input type="text" name="nationality" placeholder="e.g. United States"></label>
          <label>Travel Dates<input type="text" name="dates" placeholder="e.g. Oct 15–22, 2026"></label>
        </div>
        <label>Number of Guests<select name="guests" required><option value="">Select…</option><option value="1">1 (Solo)</option><option value="2">2 (Couple)</option><option value="3-4">3–4 (Small group / Family)</option><option value="5-8">5–8 (Medium group)</option><option value="9+">9+ (Large group)</option></select></label>
        <label>Interested In<select name="interest"><option value="">Select all that apply…</option><option value="great-wall">Great Wall Tour</option><option value="forbidden-city">Forbidden City Tour</option><option value="temple-hutong">Temple of Heaven & Hutongs</option><option value="summer-palace">Summer Palace & Lama Temple</option><option value="inner-mongolia">Inner Mongolia Extension</option><option value="tibet">Tibet Extension</option><option value="hotel-only">Hotel Booking Only</option><option value="custom">Custom / Not Sure Yet</option></select></label>
        <label>Your Message<textarea name="message" placeholder="Tell us about your travel preferences, special requests, or any questions..." required></textarea></label>
        <button type="submit" class="btn btn--ghost" id="submitBtn">Submit Inquiry<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></button>
      </form>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer">
  <div class="container">
    <div class="footer__inner">
      <div class="footer__brand"><span class="footer__brand-icon">龙</span><span>Happy Dragon Tours</span></div>
      <ul class="footer__links"><li><a href="#hotels">Hotels</a></li><li><a href="#tours">Tours</a></li><li><a href="#journeys">Extended</a></li><li><a href="#testimonials">Reviews</a></li><li><a href="#booking">Contact</a></li></ul>
    </div>
    <div class="footer__divider"></div>
    <div class="footer__bottom">
      <span>&copy; 2026 Happy Dragon Tours. All rights reserved.</span>
    </div>
  </div>
</footer>

<script>
/* Nav scroll */
const nav = document.getElementById('nav'), hero = document.getElementById('hero');
new IntersectionObserver(([e]) => nav.classList.toggle('nav--solid', !e.isIntersecting), { rootMargin: '-64px 0px 0px' }).observe(hero);

/* Mobile menu */
const toggle = document.getElementById('navToggle'), links = document.getElementById('navLinks');
toggle.addEventListener('click', () => links.classList.toggle('nav__links--open'));
links.querySelectorAll('a').forEach(a => a.addEventListener('click', () => links.classList.remove('nav__links--open')));

/* Lucide icons */
lucide.createIcons();

/* Scroll animations */
const animEls = document.querySelectorAll('.hotel-card, .tour-card, .journey-card, .test-card, .about__stat');
new IntersectionObserver((entries) => { entries.forEach(e => { if(e.isIntersecting){ e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; }}); }, { threshold: .12 }).observe(animEls);
document.querySelectorAll('.hotel-card, .tour-card, .journey-card, .test-card, .about__stat').forEach(el => { el.style.opacity = '0'; el.style.transform = 'translateY(24px)'; el.style.transition = 'opacity 600ms ease-out, transform 600ms ease-out'; });
/* Re-observe after setting initial styles */
setTimeout(() => {
  document.querySelectorAll('.hotel-card, .tour-card, .journey-card, .test-card, .about__stat').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(24px)';
    el.style.transition = 'opacity 600ms ease-out, transform 600ms ease-out';
  });
  document.querySelectorAll('.hotel-card, .tour-card, .journey-card, .test-card, .about__stat').forEach(el => {
    const obs = new IntersectionObserver((entries) => { entries.forEach(e => { if(e.isIntersecting){ e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; }}); }, { threshold: .12 });
    obs.observe(el);
  });
}, 100);

/* Booking form submission via API */
document.getElementById('bookingForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = 'Sending...';
  const msg = document.getElementById('formMessage');
  try {
    const form = new FormData(this);
    const data = Object.fromEntries(form.entries());
    const res = await fetch('/api/booking', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const json = await res.json();
    if (json.success) {
      msg.style.display = 'block';
      msg.innerHTML = 'Thanks, ' + data.name + '! Your inquiry has been received. We will respond within 24 hours.';
      this.reset();
      btn.textContent = 'Submitted ✓';
    } else {
      throw new Error(json.error);
    }
  } catch(err) {
    msg.style.display = 'block';
    msg.innerHTML = 'Something went wrong. Please email us directly at <%= settings.contact_email %>.';
    btn.disabled = false;
    btn.textContent = 'Submit Inquiry';
  }
});
</script>
</body>
</html>
