<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Bookings · Happy Dragon Tours</title><link rel="stylesheet" href="/css/admin.css"></head>
<body><div class="admin-layout">
<%- include('layout') %>
<div class="main-content">
  <div class="page-header"><h1>Bookings</h1></div>
  <% if (bookings.length === 0) { %>
  <div class="empty"><p>No booking inquiries yet.</p></div>
  <% } else { %>
  <div class="table-wrap">
    <table><thead><tr><th>Date</th><th>Name</th><th>Email</th><th class="hide-mobile">Nationality</th><th class="hide-mobile">Interest</th><th>Status</th><th></th></tr></thead><tbody>
    <% bookings.forEach(b => { %>
    <tr>
      <td style="white-space:nowrap;font-size:.8rem"><%= new Date(b.created_at).toLocaleDateString() %><br><span style="font-size:.7rem;color:var(--muted)"><%= new Date(b.created_at).toLocaleTimeString() %></span></td>
      <td><strong><%= b.name %></strong></td>
      <td><%= b.email %></td>
      <td class="hide-mobile"><%= b.nationality || '—' %></td>
      <td class="hide-mobile"><%= b.interest || '—' %></td>
      <td><% if (b.status === 'new') { %><span class="tag"><%= b.status %></span><% } else { %><%= b.status %><% } %></td>
      <td style="white-space:nowrap">
        <a href="/admin/bookings/mark/<%= b.id %>" class="btn btn--sm btn--outline">Mark Read</a>
        <button class="btn btn--sm btn--outline" onclick="var d=document.getElementById('msg<%= b.id %>');d.style.display=d.style.display==='none'?'block':'none'">Message</button>
        <a href="/admin/bookings/delete/<%= b.id %>" class="btn btn--sm btn--danger" onclick="return confirm('Delete this booking?')">Delete</a>
      </td>
    </tr>
    <tr><td colspan="7" style="padding:0 16px"><div id="msg<%= b.id %>" style="display:none;padding:8px 0">
      <div class="booking-message">
        <strong>Guests:</strong> <%= b.guests || 'Not specified' %><br>
        <strong>Travel Dates:</strong> <%= b.travel_dates || 'Not specified' %><br>
        <strong>Message:</strong> <%= b.message || 'No message' %>
      </div>
    </div></td></tr>
    <% }) %>
    </tbody></table>
  </div>
  <style>.hide-mobile{display:table-cell}@media(max-width:768px){.hide-mobile{display:none}}</style>
  <% } %>
</div></div></body>
</html>
