<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title><%= hotel ? 'Edit' : 'Add' %> Hotel · Happy Dragon Tours</title><link rel="stylesheet" href="/css/admin.css"></head>
<body><div class="admin-layout">
<%- include('layout') %>
<div class="main-content">
  <div class="page-header"><h1><%= hotel ? 'Edit Hotel' : 'Add Hotel' %></h1></div>
  <div class="form-card">
    <form method="post" action="/admin/hotels/save" enctype="multipart/form-data">
      <% if (hotel) { %><input type="hidden" name="id" value="<%= hotel.id %>"><% } %>
      <div class="form-group"><label>Hotel Name</label><input name="name" value="<%= hotel ? hotel.name : '' %>" required></div>
      <div class="form-group"><label>Location</label><input name="location" value="<%= hotel ? hotel.location : '' %>"></div>
      <div class="form-group"><label>Description</label><textarea name="description" rows="4"><%= hotel ? hotel.description : '' %></textarea></div>
      <div class="form-group"><label>Tags (comma separated)</label><input name="tags" value="<%= hotel ? hotel.tags : '' %>"><div class="hint">e.g. Free WiFi,Breakfast Included,Airport Shuttle</div></div>
      <div class="form-group"><label>Long Description (detail page)</label><textarea name="long_description" rows="4" placeholder="Extended description shown on the hotel detail page."></textarea></div>
      <div class="form-group"><label>Sort Order</label><input name="sort_order" type="number" value="<%= hotel ? hotel.sort_order : 0 %>"></div>
      <div class="form-group"><label>Image</label>
        <% if (hotel && hotel.image) { %><p style="margin-bottom:6px;font-size:.82rem;color:var(--muted)">Current: <%= hotel.image %></p><% } %>
        <input type="hidden" name="existing_image" value="<%= hotel ? hotel.image : '' %>">
        <input type="file" name="image" accept="image/*">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn--primary">Save</button>
        <a href="/admin/hotels" class="btn btn--outline">Cancel</a>
      </div>
    </form>
  </div>
</div></div></body>
</html>
