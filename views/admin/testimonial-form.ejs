<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title><%= testimonial ? 'Edit' : 'Add' %> Testimonial</title><link rel="stylesheet" href="/css/admin.css"></head>
<body><div class="admin-layout">
<%- include('layout') %>
<div class="main-content">
  <div class="page-header"><h1><%= testimonial ? 'Edit Review' : 'Add Review' %></h1></div>
  <div class="form-card">
    <form method="post" action="/admin/testimonials/save">
      <% if (testimonial) { %><input type="hidden" name="id" value="<%= testimonial.id %>"><% } %>
      <div class="form-group" style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label>Guest Name</label><input name="name" value="<%= testimonial ? testimonial.name : '' %>" required></div>
        <div><label>Origin / Country</label><input name="origin" value="<%= testimonial ? testimonial.origin : '' %>" placeholder="e.g. United Kingdom"></div>
      </div>
      <div class="form-group" style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><label>Avatar Initials</label><input name="avatar_initials" value="<%= testimonial ? testimonial.avatar_initials : '' %>" placeholder="e.g. SM" maxlength="2"></div>
        <div><label>Rating (1-5)</label><input name="rating" type="number" min="1" max="5" value="<%= testimonial ? testimonial.rating : 5 %>"></div>
      </div>
      <div class="form-group"><label>Review Text</label><textarea name="text" rows="5"><%= testimonial ? testimonial.text : '' %></textarea></div>
      <div class="form-group"><label>Sort Order</label><input name="sort_order" type="number" value="<%= testimonial ? testimonial.sort_order : 0 %>"></div>
      <div class="form-actions">
        <button type="submit" class="btn btn--primary">Save</button>
        <a href="/admin/testimonials" class="btn btn--outline">Cancel</a>
      </div>
    </form>
  </div>
</div></div></body>
</html>
