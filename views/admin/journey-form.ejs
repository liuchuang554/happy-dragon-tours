<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title><%= journey ? 'Edit' : 'Add' %> Journey · Happy Dragon Tours</title><link rel="stylesheet" href="/css/admin.css"></head>
<body><div class="admin-layout">
<%- include('layout') %>
<div class="main-content">
  <div class="page-header"><h1><%= journey ? 'Edit Journey' : 'Add Journey' %></h1></div>
  <div class="form-card">
    <form method="post" action="/admin/journeys/save" enctype="multipart/form-data">
      <% if (journey) { %><input type="hidden" name="id" value="<%= journey.id %>"><% } %>
      <div class="form-group" style="display:grid;grid-template-columns:1fr 2fr;gap:12px">
        <div><label>Region</label><input name="region" value="<%= journey ? journey.region : '' %>" placeholder="e.g. Inner Mongolia" required></div>
        <div><label>Title</label><input name="title" value="<%= journey ? journey.title : '' %>" required></div>
      </div>
      <div class="form-group"><label>Description</label><textarea name="description" rows="4"><%= journey ? journey.description : '' %></textarea></div>
      <div class="form-group"><label>Long Description</label><textarea name="long_description" rows="5" placeholder="Extended description shown on the detail page."></textarea></div>
      <div class="form-group"><label>Highlights (comma separated)</label><textarea name="highlights" rows="3" placeholder="e.g. English-speaking local guide, Accommodation included, All transport & transfers"></textarea></div>
      <div class="form-group"><label>Sort Order</label><input name="sort_order" type="number" value="<%= journey ? journey.sort_order : 0 %>"></div>
      <div class="form-group"><label>Image</label>
        <% if (journey && journey.image) { %><p style="margin-bottom:6px;font-size:.82rem;color:var(--muted)">Current: <%= journey.image %></p><% } %>
        <input type="hidden" name="existing_image" value="<%= journey ? journey.image : '' %>">
        <input type="file" name="image" accept="image/*">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn--primary">Save</button>
        <a href="/admin/journeys" class="btn btn--outline">Cancel</a>
      </div>
    </form>
  </div>
</div></div></body>
</html>
