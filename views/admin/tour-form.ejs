<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title><%= tour ? 'Edit' : 'Add' %> Tour · Happy Dragon Tours</title><link rel="stylesheet" href="/css/admin.css"></head>
<body><div class="admin-layout">
<%- include('layout') %>
<div class="main-content">
  <div class="page-header"><h1><%= tour ? 'Edit Tour' : 'Add Tour' %></h1></div>
  <div class="form-card">
    <form method="post" action="/admin/tours/save" enctype="multipart/form-data">
      <% if (tour) { %><input type="hidden" name="id" value="<%= tour.id %>"><% } %>
      <div class="form-group"><label>Tour Title</label><input name="title" value="<%= tour ? tour.title : "" %>" required></div>
      <div class="form-group"><label>Label</label><input name="label" value="<%= tour ? tour.label : "" %>" placeholder="e.g. Best Seller, Cultural, Scenic"></div>
      <div class="form-group"><label>Description</label><textarea name="description" rows="4"><%= tour ? tour.description : "" %></textarea></div>
      <div class="form-group" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
        <div><label>Duration</label><input name="duration" value="<%= tour ? tour.duration : "" %>" placeholder="e.g. Full day"></div>
        <div><label>Tour Type</label><input name="tour_type" value="<%= tour ? tour.tour_type : "" %>" placeholder="e.g. Private or Group"></div>
        <div><label>Price</label><input name="price" value="<%= tour ? tour.price : "" %>" placeholder="e.g. $89"></div>
      </div>
      <div class="form-group"><label>Long Description (detail page)</label><textarea name="long_description" rows="5" placeholder="Extended description shown on the detail page."><%= tour ? tour.long_description : "" %></textarea></div>
      <div class="form-group"><label>Highlights (comma separated)</label><textarea name="highlights" rows="3" placeholder="e.g. English guide, Hotel pickup, Entrance fees"><%= tour ? tour.highlights : "" %></textarea></div>
      <div class="form-group"><label>Sort Order</label><input name="sort_order" type="number" value="<%= tour ? tour.sort_order : 0 %>"></div>
      <div class="form-group"><label>Image</label>
        <% if (tour && tour.image) { %><p style="margin-bottom:6px;font-size:.82rem;color:var(--muted)">Current: <%= tour.image %></p><% } %>
        <input type="hidden" name="existing_image" value="<%= tour ? tour.image : "" %>">
        <input type="file" name="image" accept="image/*">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn--primary">Save</button>
        <a href="/admin/tours" class="btn btn--outline">Cancel</a>
      </div>
    </form>
  </div>
</div></div></body>
</html>
